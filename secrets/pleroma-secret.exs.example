# Vorlage für secrets/<hostname>/pleroma-secret.age
# Kein DB-Passwort — PostgreSQL läuft per Unix-Socket (Peer-Auth).
import Config

config :pleroma, Pleroma.Web.Endpoint,
  secret_key_base: "GENERATE_WITH_openssl_rand_hex_64",
  signing_salt: "GENERATE_WITH_openssl_rand_hex_16"

config :web_push_encryption, :vapid_details,
  public_key: "GENERATE_VAPID_PUBLIC",
  private_key: "GENERATE_VAPID_PRIVATE"
